GROQ_API_KEY=your_groq_key_here
VIDEO_SOURCE=demo/samples/construction.mp4

# Gmail SMTP (for email alerts)
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Twilio (for SMS alerts)
TWILIO_ACCOUNT_SID=ACxxxx
TWILIO_AUTH_TOKEN=xxxx
TWILIO_FROM=+1xxxxxxxxxx

# Police contacts
POLICE_EMAIL=police@city.gov
POLICE_PHONE=+1xxxxxxxxxx

# Emergency contacts (medical)
EMERGENCY_EMAIL=emergency@hospital.com
EMERGENCY_PHONE=+1xxxxxxxxxx

# System owner (receives all alerts)
OWNER_EMAIL=owner@example.com
OWNER_PHONE=+1xxxxxxxxxx
